// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  industry     String?
  location     String?
  url          String?
  applications Application[]
  contacts     Contact[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("companies")
}

model Application {
  id             Int       @id @default(autoincrement())
  companyId      Int
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobTitle       String
  dateApplied    DateTime?
  source         String?
  postingUrl     String?
  expectedSalary Int?
  stage          Stage     @default(WISHLIST)
  resumeVersion  String?
  notes          Note[]
  todos          Todo[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("applications")
}

model Note {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title         String
  content       String
  type          NoteType    @default(GENERAL)
  eventDate     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("notes")
}

model Todo {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title         String
  completed     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("todos")
}

model Contact {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  role        String?
  email       String?
  phone       String?
  linkedInUrl String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contacts")
}

enum Stage {
  WISHLIST
  APPLIED
  ASSESSMENT
  INTERVIEW
  OFFERED
  REJECTED
}

enum NoteType {
  GENERAL
  INTERVIEW
  ASSESSMENT
  FEEDBACK
}
